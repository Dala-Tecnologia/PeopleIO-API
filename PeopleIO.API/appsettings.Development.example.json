{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "KeyVault": {
    "Url": "https://<seu-keyvault>.vault.azure.net/"
  },
  "ConnectionStrings": {
    "PostgreSQL": "Host=<host>; Database=<db>; Username=<user>; Password=<senha>; SSL Mode=VerifyFull;"
  },
  "AzureDocumentIntelligence": {
    "Endpoint": "https://<seu-recurso>.cognitiveservices.azure.com/"
  },
  "AzureAd": {
    "Instance": "https://<tenant-id>.ciamlogin.com/",
    "Domain": "<dominio>.onmicrosoft.com",
    "TenantId": "<tenant-id>",
    "ClientId": "<client-id>",
    "Audience": "<client-id>",
    "Scopes": "API.Access",
    "CallbackPath": "/signin-oidc"
  }
}
